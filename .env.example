# Port for story-ai service
PORT=50052
GRPC_PORT=50052

# Alibaba DashScope (Qwen) — https://dashscope.console.aliyun.com/apiKey
API_KEY=your_dashscope_api_key_here
BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Model options (cheapest → most powerful):
#   qwen-turbo       — nhanh, rẻ nhất
#   qwen-plus        — cân bằng chất lượng/giá (recommended)
#   qwen-max         — chất lượng cao nhất
#   qwen3-235b-a22b  — Qwen3 mới nhất (có thinking)
#   qwen3-30b-a3b    — Qwen3 nhỏ hơn, rẻ hơn
MODEL_NAME=qwen-plus
